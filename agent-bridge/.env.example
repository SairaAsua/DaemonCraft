# DaemonCraft Agent Bridge Configuration

# Flask Server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
FLASK_ENV=production

# Bot Registry (comma-separated list of bot API URLs)
# Format: name=http://host:port,name2=http://host2:port2
BOT_REGISTRY=DaemonBot=http://localhost:3000

# Authentication (optional, for production)
# API_KEY=your-secret-api-key

# Logging
LOG_LEVEL=INFO
LOG_FILE=agent-bridge.log

# Hermes CLI Integration
HERMES_WEBHOOK_URL=
HERMES_API_KEY=

# Trigger Settings
TRIGGER_TIMEOUT=30
MAX_CONCURRENT_TRIGGERS=10

# Mod Integration Flags
ENABLE_COMPUTERCRAFT=false
ENABLE_CREATE_MOD=false
ENABLE_INDUSTRIAL=false
